# --- Database ---
# Local Postgres (docker-compose or scripts/start-db.ps1). Locally DIRECT_URL
# can mirror DATABASE_URL.
DATABASE_URL="postgresql://tennis:tennis@localhost:5432/tennis_predictor?schema=public"
DIRECT_URL="postgresql://tennis:tennis@localhost:5432/tennis_predictor?schema=public"
#
# Production (Supabase) — from the dashboard "Connect" button:
#   DATABASE_URL = Transaction pooler (port 6543), app runtime. Keep ?pgbouncer=true
#   DIRECT_URL   = Session pooler (port 5432), used by prisma migrate
# DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# --- NextAuth ---
# Generate one with: openssl rand -base64 32   (or: npx auth secret)
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# --- Claude API (dashboard tennis news section) ---
# Get a key at https://console.anthropic.com/ (Get API Keys). Server-side only —
# never exposed to the browser. Without it, the news section shows "unavailable"
# instead of breaking the dashboard.
ANTHROPIC_API_KEY=""

# --- Brand tagline (optional) ---
# Small pill shown next to the logo on every page. Public — inlined into the
# browser bundle at build time. Leave unset to hide it entirely.
NEXT_PUBLIC_BRAND_TAGLINE=""

# --- Seed admin (used by prisma/seed.ts) ---
SEED_ADMIN_EMAIL="admin@tennispredictor.local"
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="Admin123!"
