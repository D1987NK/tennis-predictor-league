// Tennis Predictor League — Prisma schema
// Target: PostgreSQL (see docker-compose.yml / DATABASE_URL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime connection. In production use Supabase's Transaction pooler (port 6543, ?pgbouncer=true).
  url       = env("DATABASE_URL")
  // Used for migrations (prisma migrate). In production use Supabase's Session pooler (port 5432).
  // Falls back to DATABASE_URL locally where a single connection is fine.
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

// Singleton (id = 1) holding admin-editable competition settings.
model AppSetting {
  id                      Int      @id @default(1)
  // Daily prediction cut-off, in Australian Eastern time (AEST, UTC+10).
  predictionCutoffEnabled Boolean  @default(true)
  predictionCutoffTime    String   @default("19:00") // "HH:MM" 24h
  // Bumped each time results are imported; drives the "results updated" splash.
  resultsUpdatedAt        DateTime?
  updatedAt               DateTime @updatedAt
}

// Singleton (id = 1) caching the latest tennis news fetched via the Claude API.
// Persisted in the DB (not memory) so it survives serverless cold starts and is
// shared across all users instead of re-fetching per request.
model NewsCache {
  id        Int      @id @default(1)
  articles  Json // NewsArticle[] — see src/lib/services/news.ts
  fetchedAt DateTime @default(now())
}

enum Tour {
  ATP
  WTA
}

enum MatchStatus {
  UPCOMING // imported, not yet published
  PUBLISHED // visible to users, predictions open
  LOCKED // match time passed, predictions closed
  FINISHED // result imported & scored
}

model User {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  totalPoints  Int      @default(0)
  rank         Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  predictions   Prediction[]
  notifications Notification[]
  auditLogs     AuditLog[]
  imports       ImportBatch[]
  duelsChallenged Duel[]        @relation("DuelChallenger")
  duelsOpposed    Duel[]        @relation("DuelOpponent")
  duelsWon        Duel[]        @relation("DuelWinner")
  duelComments    DuelComment[]

  @@index([totalPoints])
}

model Match {
  id           String      @id @default(cuid())
  tournament   String
  draw         String // raw draw string from CSV, e.g. "ATP Singles" / "Men's Singles"
  tour         Tour
  round        String?
  bestOf       Int         @default(3) // 3 or 5; auto-derived on import
  matchDate    DateTime    @db.Date
  timeBst      String? // "13:30"
  timeAest     String? // "22:30"
  startsAt     DateTime // resolved UTC instant used for locking predictions
  player1      String
  player2      String
  status       MatchStatus @default(UPCOMING)
  winner       String?
  finalScore   String? // e.g. "3-1"
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])

  sets        MatchSet[]
  predictions Prediction[]
  duels       Duel[]

  // A scheduled match is unique by tournament + date + the two players
  @@unique([tournament, matchDate, player1, player2], name: "match_identity")
  @@index([matchDate, status])
  @@index([tour])
}

model MatchSet {
  id           String @id @default(cuid())
  matchId      String
  match        Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  setNumber    Int
  player1Games Int
  player2Games Int

  @@unique([matchId, setNumber])
}

model Prediction {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId        String
  match          Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  predictedWinner String
  predictedScore  String // e.g. "3-1"
  // Predicted set games, stored as JSON: [{ "p1": 6, "p2": 4 }, ...]
  predictedSets   Json
  pointsAwarded   Int?
  winnerCorrect   Boolean  @default(false)
  scoreCorrect    Boolean  @default(false)
  // Sets where the predicted winner of that set matched (any score) — a
  // superset of setsCorrect, since an exact score match always implies a
  // correct set winner too.
  setWinnersCorrect Int    @default(0)
  setsCorrect     Int      @default(0) // sets where the exact games also matched
  scoredAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, matchId])
  @@index([matchId])
}

enum DuelStatus {
  PENDING // challenge sent, awaiting the opponent's response
  ACCEPTED // opponent accepted — duel is live, comments open
  DECLINED // opponent declined — terminal
  CANCELLED // challenger withdrew before a response — terminal
  COMPLETED // the underlying match finished & was scored — duel resolved
}

// A private 1-vs-1 challenge between two users predicting the same match.
// Deliberately does NOT store its own prediction — each side's "prediction"
// for the duel is simply their normal league Prediction row for `matchId`,
// so duels are a social layer on top of the existing prediction/scoring
// pipeline rather than a parallel system. Resolves automatically (winner by
// higher pointsAwarded on that match) when results are imported.
model Duel {
  id            String     @id @default(cuid())
  challengerId  String
  challenger    User       @relation("DuelChallenger", fields: [challengerId], references: [id], onDelete: Cascade)
  opponentId    String
  opponent      User       @relation("DuelOpponent", fields: [opponentId], references: [id], onDelete: Cascade)
  matchId       String
  match         Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  stake         Int        @default(0) // bragging-rights points figure shown in the UI; not deducted from totalPoints
  status        DuelStatus @default(PENDING)
  winnerId      String? // null until COMPLETED; also null on a draw
  winner        User?      @relation("DuelWinner", fields: [winnerId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  comments DuelComment[]

  @@index([challengerId])
  @@index([opponentId])
  @@index([matchId])
}

model DuelComment {
  id        String    @id @default(cuid())
  duelId    String
  duel      Duel      @relation(fields: [duelId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   String
  createdAt DateTime  @default(now())
  editedAt  DateTime? // null = never edited
  deletedAt DateTime? // soft delete — hidden from users, retained for admin moderation

  @@index([duelId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  read      Boolean  @default(false)
  // Optional structured payload (points breakdown, new rank, etc.)
  meta      Json?
  createdAt DateTime @default(now())

  @@index([userId, read])
}

enum ImportType {
  MATCHES
  RESULTS
}

model ImportBatch {
  id           String     @id @default(cuid())
  type         ImportType
  fileName     String?
  uploadedById String?
  uploadedBy   User?      @relation(fields: [uploadedById], references: [id])
  rowsTotal    Int        @default(0)
  rowsValid    Int        @default(0)
  rowsInvalid  Int        @default(0)
  summary      Json? // structured summary returned to the admin
  createdAt    DateTime   @default(now())

  matches Match[]
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String // e.g. "IMPORT_MATCHES", "PUBLISH_MATCHES", "IMPORT_RESULTS", "RESET_COMPETITION"
  detail    Json?
  createdAt DateTime @default(now())

  @@index([action, createdAt])
}
